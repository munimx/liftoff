# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_PREFIX=api
WEBHOOK_BASE_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# Database / Queue
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://liftoff:liftoff@localhost:5432/liftoff
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
JWT_SECRET=<64-hex-characters>
JWT_REFRESH_SECRET=<64-hex-characters>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GITHUB_CLIENT_ID=<github-oauth-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-client-secret>
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=<40-hex-characters>

# ------------------------------------------------------------------------------
# DigitalOcean
# ------------------------------------------------------------------------------
DO_API_TOKEN=<digitalocean-platform-api-token>
DO_SPACES_ACCESS_KEY=<digitalocean-spaces-access-key>
DO_SPACES_SECRET_KEY=<digitalocean-spaces-secret-key>
DO_SPACES_BUCKET=liftoff-pulumi-state
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DOCR_NAME=liftoff

# ------------------------------------------------------------------------------
# Pulumi / Encryption
# ------------------------------------------------------------------------------
PULUMI_PASSPHRASE=<pulumi-passphrase>
ENCRYPTION_KEY=<64-hex-characters>

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
